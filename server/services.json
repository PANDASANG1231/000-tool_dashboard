      "env": {},
      "port": 3000,
      "frontendUrl": null
    },
    {
      "id": "video-transcriptor",
      "name": "Video Transcriptor",
      "group": "local",
      "command": "which ffmpeg || /opt/homebrew/bin/brew install ffmpeg && .venv/bin/pip install -q -r requirements.txt && .venv/bin/streamlit run app.py --server.headless true",
      "workDir": "/Users/pandasang/Desktop/toolkit/20260303_vedio_transcrip_text",
      "env": {},
      "port": 8501,
      "frontendUrl": "http://localhost:8501"
    },
    {
      "id": "xhs-mcp",
      "name": "小红书 MCP",
      "group": "local",
      "command": "./xiaohongshu-mcp-darwin-arm64",
      "workDir": "/Users/pandasang/Desktop/toolkit/xhs",
      "env": {},
      "port": null,
      "frontendUrl": null
    },
    {
      "id": "daycare-tracker",
      "name": "Daycare Email Tracker",
      "group": "local",
      "command": "python3 -m http.server 8502",
      "workDir": "/Users/pandasang/Desktop/toolkit/20260311_email_to_daycare",
      "env": {},
      "port": 8502,
      "frontendUrl": "http://localhost:8502"
    },
    {
      "id": "litellm-proxy",
      "name": "LiteLLM Proxy",
      "group": "local",
      "command": "litellm --config config.yaml --port 4000",
      "workDir": "/Users/pandasang/Desktop/toolkit/20260313_litellm_cheaper_token",
      "env": {
        "ANTHROPIC_API_KEY": "$ANTHROPIC_API_KEY",
        "OPENAI_API_KEY": "$OPENAI_API_KEY",
        "DEEPSEEK_API_KEY": "$DEEPSEEK_API_KEY",
        "LOG_LEVEL": "info"
      },
      "port": 4000,
      "frontendUrl": "http://localhost:4000"
    }
